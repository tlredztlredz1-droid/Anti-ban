-- Ofuscação de string e ofuscação de chamadas
local function O(str)
    local bytes = {string.byte(str, 1, -1)}
    for i = 1, #bytes do
        bytes[i] = bytes[i] ~= 0x5A
    end
    return string.char(table.unpack(bytes))
end

