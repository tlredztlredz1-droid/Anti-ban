-- Detecção de ambiente e execução stealth
local function stealthExecute()
    local success, err = pcall(function()
        -- Verifica se está em um ambiente que pode ser detectado
        if not gs.script or not gs.script.Name then
            gs.script = fakeEnv.script
        end
        
        -- Sobrescreve a função de checagem de scripts se existir
        local mt = getrawmetatable(game)
        if mt then
            setreadonly(mt, false)
            local oldNamecall = mt.__namecall
            mt.__namecall = newcclosure(function(...)
                local args = {...}
                local method = getnamecallmethod()
                
                -- Bloqueia chamadas de detecção comuns
                if method == O("\x23\x38\x24\x2c\x2a") or method == O("\x20\x28\x2c\x2c\x35\x3c\x31") then
                    if type(args[2]) == O("\x34\x35\x33\x3c\x3b\x28") then
                        local check = tostring(args[2])
                        -- Retorna nil/não encontrado para scripts suspeitos
                        if check:find(O("\x34\x2a\x33\x28\x31\x35")) or
                           check:find(O("\x37\x28\x2c\x2c")) then
                            return nil
                        end
                    end
                end
                
                return oldNamecall(...)
            end)
            setreadonly(mt, true)
        end
    end)
    return success
end

-- Anti-AFK com delays randômicos realistas
local function antiAFK()
    local player = game.Players.LocalPlayer
    if not player then return end
    
    -- Movimentos humanos randômicos
    local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if humanoid and humanoid.Health > 0 then
        -- Simula movimento mínimo
        local randomDelay = math.random(300, 700)
        task.wait(randomDelay / 1000)
    end
end

-- Anti-Kick com hook de eventos
local function antiKick()
    local player = game.Players.LocalPlayer
    
    -- Hook no evento de kick
    local kickEvent = player:FindFirstChild("Kick") or player:FindFirstChild("kick")
    if kickEvent then
        kickEvent:Destroy()
    end
    
    -- Hook no evento de banimento
    local banEvent = player:FindFirstChild("Ban") or player:FindFirstChild("ban")
    if banEvent then
        banEvent:Destroy()
    end
end

-- Execução com proteção contra detectores de script
