-- Camada 1: Ofuscação Polimórfica Avançada
local function P(str, seed)
    seed = seed or 0x1A2B3C4D
    local result = {}
    for i = 1, #str do
        local byte = string.byte(str, i)
        byte = byte ~ (seed + i * 0x7F) % 256
        table.insert(result, string.char(byte))
    end
    return table.concat(result)
end

