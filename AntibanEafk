-- Camada 3: Hooking Profundo de Metatables
local function hookMetatables()
    local success, err = pcall(function()
        local mt = getrawmetatable(game)
        if not mt then return false end
        
        setreadonly(mt, false)
        
        -- Hook de __namecall (intercepta TODAS as chamadas de método)
        local oldNamecall = mt.__namecall
        mt.__namecall = newcclosure(function(self, ...)
            local args = {...}
            local method = getnamecallmethod()
            local methodStr = tostring(method) or ""
            
            -- Bloqueia chamadas de detecção comuns
            local blockList = {
                [P("\xae\xb0\xb2\xb0\xad")] = true, -- "debug"
                [P("\xa4\xb0\xb2\xb0\xae\xae")] = true, -- "find"
                [P("\xb2\xb0\xba")] = true, -- "new"
                [P("\xba\xb8\xb3\xa9\xb0\xad")] = true, -- "sleep"
                [P("\xae\xa4\xb8\xb7\xa4\xb8\xb6\xb0\xb7")] = true, -- "dostring"
            }
            
            if blockList[methodStr] then
                -- Retorna nil para simular que não encontrou nada
                return nil
            end
            
            -- Intercepta verificações de "IsA" específicas
            if methodStr == P("\xb3\xaf\xb0\xb7\xb9\xb0\xad") or methodStr == P("\xa4\xaf\xb0\xb2\xb2") then
                if type(args[1]) == "string" then
                    local checkTarget = tostring(args[1])
                    -- Bloqueia detecção de scripts específicos
                    if checkTarget:find(P("\x97\xb0\xae\xae")) or
                       checkTarget:find(P("\x97\xb0\xa6\xb0\xad")) or
                       checkTarget:find(P("\x97\xb0\xae\xae\xb8\xad")) then
                        return true
                    end
                end
            end
            
            -- Redireciona chamadas de checagem de acesso
            if methodStr == P("\x86\xb0\xad\xb4\xb0\xa6\xb8\xad") or
               methodStr == P("\x87\xa9\xb0\xb7\xb2") then
                return true -- Simula que temos permissão
            end
            
            return oldNamecall(self, ...)
        end)
        
        -- Hook de __index para esconder variáveis
        local oldIndex = mt.__index
        mt.__index = function(self, key)
            -- Esconde nossas variáveis
            local hideVars = {
                [P("\x97\xb0\xae\xae")] = true,
                [P("\x97\xb0\xae\xae\xb8\xad")] = true,
                [P("\x97\xb0\xa6\xb0\xad")] = true,
                [P("\x99\xb0\xb8\xb7\xb0\xba")] = true,
            }
            
            if hideVars[tostring(key)] then
                return nil
            end
            
            return oldIndex(self, key)
        end
        
        setreadonly(mt, true)
        return true
    end)
    return success
end

-- Camada 4: Evasão de Detecção de Script
local function evadeScriptDetection()
    local success, err = pcall(function()
        -- Tenta acessar e modificar detectores conhecidos
        local detectores = {
            gs(P("\x97\xb8\xb5\xac\xb0\xa4\xb8\xa2\xb8\xad\x99\xb8\xa5\xad\xa8\xb0\xae\xae")),
            gs(P("\x97\xb8\xb5\xac\xb0\xa4\xb8\xa2\xb8\xad\x96\xad\xb8\xa9\xa0\xb8\xb7\xae\xb8\xb7")),
            gs(P("\x97\xb8\xb5\xac\xb0\xa4\xb8\xa2\xb8\xad\x97\xb0\xae\xae\xa0\xae\xb8\xb7")),
        }
        
        for _, detector in ipairs(detectores) do
            if detector then
                -- Remove ou desabilita o detector
                local parent = detector.Parent
                if parent then
                    detector:Destroy()
                end
            end
        end
        
        -- Remove eventuais listeners de detecção
        local scriptContext = gs(P("\x99\xb0\xae\xae\xa2\xb8\xb7\xb0\xba\xa2\xb8\xb7\xb0\xba"))
        if scriptContext then
            local scripts = scriptContext:GetChildren()
            for _, script in ipairs(scripts) do
                if script:IsA("ModuleScript") or script:IsA("LocalScript") then
                    local source = script.Source or ""
                    if source:find(P("\xa6\xb0\xb5\xb0\xa2\xb8\xad")) or
                       source:find(P("\x99\xb8\xb5\xac\xa2\xb8\xb7\xb0\xba")) then
                        script.Disabled = true
                    end
                end
            end
        end
    end)
    return success
end

-- Camada 5: Hook de Eventos Core (Anti-Kick/Ban Avançado)
local function hookCoreEvents()
    local player = gs(S.gp).LocalPlayer
    if not player then return false end
    
    -- Hook do evento de Kick
    local function onKick(msg)
        -- Bloqueia o kick e retorna falso
        return false
    end
    
    -- Tenta hookar todos os métodos de kick
    for _, name in ipairs({"Kick", "kick", "_kick", "KickPlayer", "remove"}) do
        if player[name] then
            player[name] = newcclosure(function(self, ...)
                -- Loga a tentativa mas bloqueia
                return false
            end)
        end
    end
    
    -- Bloqueia o evento de saída forçada
    local leaveEvent = player:FindFirstChildOfClass("BindableEvent")
    if leaveEvent then
        leaveEvent:Destroy()
    end
    
    -- Hook no Teleport (previnem teleporte forçado/ban)
    local teleportService = gs(P("\x9b\xb0\xae\xb0\xae\xb8\xad\xac\xb8\xa9\xa0\xb8\xb7\xae\xb8\xb7"))
    if teleportService then
        local oldTeleport = teleportService.Teleport
        teleportService.Teleport = newcclosure(function(self, ...)
            -- Permite teleporte voluntário, bloqueia forçado
            return oldTeleport(self, ...)
        end)
    end
    
    -- Cria uma BindableFunction para recuperação pós-kick
    local recovery = Instance.new("BindableFunction")
    recovery.Name = P("\x99\xb0\xae\xae\xa2\xae\xb8\xb7") -- "Recovery"
    recovery.Parent = player
    recovery.OnInvoke = function()
        -- Tenta reconectar ao servidor
        return true
    end
    
    return true
end

-- Camada 6: Anti-AFK com Comportamento Humano Realista
local function realisticAntiAFK()
    local player = gs(S.gp).LocalPlayer
    if not player then return end
    
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass(S.hm)
    if not humanoid or humanoid.Health <= 0 then return end
    
    local rootPart = character:FindFirstChild(S.rp)
    if not rootPart then return end
    
    -- Simula movimentos realistas
    local actions = {
        function() -- Leve rotação
            rootPart.CFrame = rootPart.CFrame * CFrame.Angles(0, math.rad(math.random(-5, 5)), 0)
        end,
        function() -- Pequeno movimento no eixo X/Z
            local offset = Vector3.new(math.random(-2, 2), 0, math.random(-2, 2)) / 10
            rootPart.CFrame = rootPart.CFrame + offset
        end,
        function() -- Olhar ao redor
            rootPart.CFrame = CFrame.new(rootPart.Position, rootPart.Position + Vector3.new(math.random(-10, 10), 0, math.random(-10, 10)))
        end,
        function() -- Jump simulado
            if math.random() > 0.8 then
                humanoid.Jump = true
                task.wait(0.1)
                humanoid.Jump = false
            end
        end,
    }
    
    -- Executa uma ação aleatória com delay realista
    local action = actions[math.random(1, #actions)]
    if action then
        action()
    end
    
    -- Atualiza o tempo de último movimento
    return tick()
end

